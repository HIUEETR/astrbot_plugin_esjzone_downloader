{
  "account": {
    "description": "ESJ Zone 账号配置",
    "type": "object",
    "items": {
      "username": {
        "description": "登录邮箱",
        "type": "string",
        "default": ""
      },
      "password": {
        "description": "登录密码",
        "type": "string",
        "default": "",
        "obvious_hint": true,
        "hint": "不建议在群聊或共享环境保存密码。聊天登录命令仅允许私聊使用，Cookie 会按用户隔离保存。"
      }
    }
  },
  "download": {
    "description": "下载配置",
    "type": "object",
    "items": {
      "file_naming_mode": {
        "description": "发送文件的命名方式",
        "type": "string",
        "default": "book_name",
        "options": [
          "book_name",
          "book_id"
        ],
        "hint": "book_name 使用书籍名作为文件名，book_id 使用 ESJ 书籍编号作为文件名。"
      },
      "use_book_dir": {
        "description": "是否为每本书创建独立目录",
        "type": "bool",
        "default": true
      },
      "download_images": {
        "description": "生成 EPUB 时下载封面和插图",
        "type": "bool",
        "default": true
      },
      "max_threads": {
        "description": "并发下载数",
        "type": "int",
        "default": 5,
        "hint": "允许范围 1-10。过高可能触发站点限流。"
      },
      "timeout_seconds": {
        "description": "请求超时时间（秒）",
        "type": "int",
        "default": 180,
        "hint": "允许范围 5-300。"
      },
      "retry_attempts": {
        "description": "失败重试次数",
        "type": "int",
        "default": 2,
        "hint": "允许范围 0-5。"
      },
      "retry_delays": {
        "description": "重试等待秒数列表",
        "type": "list",
        "default": [
          1,
          3,
          5
        ],
        "hint": "最多 5 项，每项允许范围 0-300 秒。"
      },
      "max_chapters_per_download": {
        "description": "单次下载最大章节数",
        "type": "int",
        "default": 300,
        "hint": "允许范围 1-1000。"
      },
      "max_images_per_download": {
        "description": "单次下载最大插图数",
        "type": "int",
        "default": 500,
        "hint": "允许范围 0-2000，不含封面。"
      },
      "max_image_bytes": {
        "description": "单张图片最大字节数",
        "type": "int",
        "default": 10485760,
        "hint": "默认 10 MiB，允许范围 1024 到 52428800。"
      },
      "max_total_image_bytes": {
        "description": "单次下载图片总字节数",
        "type": "int",
        "default": 104857600,
        "hint": "默认 100 MiB，允许范围 1024 到 524288000。"
      },
      "max_image_pixels": {
        "description": "单张图片最大像素数",
        "type": "int",
        "default": 20000000,
        "hint": "用于限制解压炸弹图片，允许范围 1000000 到 100000000。"
      },
      "max_output_bytes": {
        "description": "生成文件最大字节数",
        "type": "int",
        "default": 157286400,
        "hint": "默认 150 MiB，允许范围 1024 到 1073741824。"
      }
    }
  },
  "monitor": {
    "description": "更新监控配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "启用自动更新监控",
        "type": "bool",
        "default": true
      },
      "interval_hours": {
        "description": "自动检查间隔（小时）",
        "type": "float",
        "default": 12,
        "hint": "允许范围 0.5-168。插件会按此间隔检查监控列表，发现新章节后发送提示并更新记录。"
      },
      "max_entries": {
        "description": "全局最大监控条目数",
        "type": "int",
        "default": 1000,
        "hint": "允许范围 1-5000。"
      },
      "max_entries_per_origin": {
        "description": "单个会话最大监控条目数",
        "type": "int",
        "default": 50,
        "hint": "允许范围 1-200。"
      },
      "check_batch_size": {
        "description": "单轮自动检查最大条目数",
        "type": "int",
        "default": 100,
        "hint": "允许范围 1-500。"
      },
      "check_concurrency": {
        "description": "监控检查并发数",
        "type": "int",
        "default": 3,
        "hint": "允许范围 1-10。"
      }
    }
  }
}
